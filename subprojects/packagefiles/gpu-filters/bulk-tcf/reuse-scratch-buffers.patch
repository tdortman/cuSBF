+	__host__ void free_scratch_buffers() {
+		if (cached_small_keys != nullptr) {
+			cudaFree(cached_small_keys);
+			cached_small_keys = nullptr;
+		}
+		cached_small_keys_n = 0;
+
+		if (cached_scrambled_hits != nullptr) {
+			cudaFree(cached_scrambled_hits);
+			cached_scrambled_hits = nullptr;
+		}
+		cached_scrambled_hits_n = 0;
+
+		if (cached_indices != nullptr) {
+			cudaFree(cached_indices);
+			cached_indices = nullptr;
+		}
+		cached_indices_n = 0;
+	}
+
+	__host__ void ensure_small_keys(uint64_t nitems) {
+		if (cached_small_keys_n < nitems) {
+			if (cached_small_keys != nullptr) {
+				cudaFree(cached_small_keys);
+			}
+			cudaMalloc((void**)&cached_small_keys, sizeof(internal_key_type) * nitems);
+			cached_small_keys_n = nitems;
+		}
+	}
+
+	__host__ void ensure_scrambled_hits(uint64_t nitems) {
+		if (cached_scrambled_hits_n < nitems) {
+			if (cached_scrambled_hits != nullptr) {
+				cudaFree(cached_scrambled_hits);
+			}
+			cudaMalloc((void**)&cached_scrambled_hits, sizeof(bool) * nitems);
+			cached_scrambled_hits_n = nitems;
+		}
+	}
+
+	__host__ void ensure_indices(uint64_t nitems) {
+		if (cached_indices_n < nitems) {
+			if (cached_indices != nullptr) {
+				cudaFree(cached_indices);
+			}
+			cudaMalloc((void**)&cached_indices, sizeof(uint64_t) * nitems);
+			cached_indices_n = nitems;
+		}
+	}
+
+	// Pre-size insert/query scratch so bulk_query_into does not grow mid-benchmark.
+	__host__ void reserve_bulk_scratch(uint64_t nitems) {
+		ensure_small_keys(nitems);
+		ensure_scrambled_hits(nitems);
+		ensure_indices(nitems);
+	}
+
 
